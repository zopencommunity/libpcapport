zopen_check_results()
{
  dir="$1"
  pfx="$2"
  chk="$1/$2_check.log"

  actualFailures=$(grep "tests failed" ${chk} | cut -d ' ' -f 1)
  actualPassed=$(grep "tests passed" ${chk} | cut -d ' ' -f 1)
  actualSkipped=$(grep "tests skipped" ${chk} | cut -d ' ' -f 1)

  TotalTests=$((actualFailures + actualPassed + actualSkipped))

  # Echo the following information to gauge build health
  echo "actualFailures:${actualFailures}"
  echo "totalTests:${TotalTests}"
  echo "totalSkipped:${actualSkipped}"
  echo "expectedFailures:${actualFailures}"
  echo "expectedTotalTests:${TotalTests}"
}

zopen_get_version()
{
  # Modify to echo the version of your tool/library
  # Rather than hardcoding the version, obtain the version by running the tool/library
  echo "1.0.0"
}
